# Mobile app environment variables (loaded automatically by Expo)
# Must be prefixed with EXPO_PUBLIC_ to be exposed to the client bundle.

# Backend URL — use your computer's LAN IP for a real device, or http://localhost:4000 for web
EXPO_PUBLIC_BACKEND_URL=http://192.168.1.10:4000

# Your numeric Telegram user ID (run /myid in the bot to get it)
EXPO_PUBLIC_TELEGRAM_ID=123456789
