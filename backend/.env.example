PORT=4000

# Supabase REST (used by the running backend)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXXX

# Supabase direct Postgres connection (used ONLY by `npm run migrate`)
# Get this from: Supabase → Project Settings → Database → Connection string (URI mode)
SUPABASE_DB_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.xxxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# Optional: real Statsig server SDK key. If unset, falls back to internal deterministic bucketing.
STATSIG_SERVER_KEY=

# Daily reminder cron (server local time). Default 19:00.
DAILY_REMINDER_CRON=0 19 * * *
DAILY_SUMMARY_CRON=0 21 * * *
